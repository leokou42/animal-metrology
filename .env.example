# === COCO Dataset (defaults to bundled test images) ===
COCO_IMAGES_DIR=./data/test_images
COCO_ANNOTATIONS_FILE=./data/test_annotations/test_instances.json
# For full COCO val2017, uncomment below:
# COCO_IMAGES_DIR=./data/coco/val2017
# COCO_ANNOTATIONS_FILE=./data/coco/annotations/instances_val2017.json

# === Segmentation Model ===
SEGMENTATION_MODEL=yolo11n-seg
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# === Eye Detection Model (RTMPose + AP-10K) ===
EYE_MODEL_PATH=weights/rtmpose_ap10k.onnx
EYE_CONFIDENCE_THRESHOLD=0.3

# === Depth Estimation ===
DEPTH_MODEL=depth-anything/Depth-Anything-V2-Small-hf
DEPTH_ENABLED=true
DEPTH_PRO_CHECKPOINT=weights/depth_pro.pt
DEPTH_DEVICE=auto

# === API Settings ===
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# === Output ===
OUTPUT_DIR=./outputs
